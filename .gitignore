# Ignore Python bytecode
__pycache__/
*.py[cod]

# Ignore Python packaging files
*.egg-info/
/dist/
/build/
src/STKO_to_python/examples/log.log
log.log

# MkDocs build output (generated by `mkdocs build`)
/site/

# pytest-benchmark storage (generated by `pytest bench/`)
/.benchmarks/

# Large MPCO fixtures kept developer-local. Tests that depend on
# these skip gracefully via their conftest fixtures, so a clean clone
# still runs the suite green. Obtain them from the original STKO
# export to enable the corresponding tests locally.
#  * Test_NLShell        — ~2 GB layered-shell MP fixture
#  * dispBeamCol         — ~600 MB displacement-based beam-column
#  * forceBeamCol        — ~13 MB force-based beam-column (small but
#                           checked in only on demand to avoid mixing
#                           recorder outputs with source)
#  * solid_partition_example — solid + fiber-beam MP fixture
stko_results_examples/Test_NLShell/
stko_results_examples/dispBeamCol/
stko_results_examples/forceBeamCol/
stko_results_examples/solid_partition_example/
